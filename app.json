{
  "expo": {
    "name": "Idara-Mohalla Attendance Mobile",
    "slug": "idara-mohalla-attendance-mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "idaramohallaattendance",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.idaramohalla.attendance",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow Attendance App to access your location to verify event check-ins.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.idaramohalla.attendance",
      "versionCode": 11,
      "adaptiveIcon": {
        "backgroundColor": "#F3E7D5",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Attendance App to access your location to verify event check-ins."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F3E7D5",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 180
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://badriattendance.duckdns.org/bgi_attendance_system",
      "router": {},
      "eas": {
        "projectId": "fa6b70b1-f20c-4b5d-9202-d4ff5c5d05f5"
      }
    }
  }
}
